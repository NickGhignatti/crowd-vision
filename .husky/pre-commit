#!/usr/bin/env sh
# Run only on staged service files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Check if any client files are staged
if echo "$STAGED_FILES" | grep -q "^client/"; then
  echo "🔍 Linting client files..."
  cd client
  npx eslint --fix $(echo "$STAGED_FILES" | grep "^client/" | sed 's|^client/||')
  cd ..
fi

# Check if any server files are staged
if echo "$STAGED_FILES" | grep -q "^server/"; then
  echo "🔍 Linting server files..."
  cd server
  npx eslint --fix --config ./eslint.config.mjs $(echo "$STAGED_FILES" | grep "^server/" | sed 's|^server/||')
  cd ..
fi


