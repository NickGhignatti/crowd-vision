#!/usr/bin/env sh
# Run only on staged service files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Lint only client source files supported by ESLint config
CLIENT_ESLINT_FILES=$(echo "$STAGED_FILES" | grep "^client/" | grep -E '\.(ts|tsx|mts|cts|js|jsx|vue)$' | sed 's|^client/||' || true)
if [ -n "$CLIENT_ESLINT_FILES" ]; then
  echo "Linting client files..."
  cd client
  npx eslint --fix $CLIENT_ESLINT_FILES
  cd ..
fi

# Lint only server source files supported by ESLint config
SERVER_ESLINT_FILES=$(echo "$STAGED_FILES" | grep "^server/" | grep -E '\.(ts|tsx|mts|cts|js|jsx|cjs)$' | sed 's|^server/||' || true)
if [ -n "$SERVER_ESLINT_FILES" ]; then
  echo "Linting server files..."
  cd server
  npx eslint --fix --config ./eslint.config.mjs $SERVER_ESLINT_FILES
  cd ..
fi


