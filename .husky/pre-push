#!/usr/bin/env sh
# Run only on changed service files
CHANGED_FILES=$(git diff origin/HEAD --name-only --diff-filter=ACM 2>/dev/null || git diff HEAD --name-only --diff-filter=ACM)

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

# Lint only changed client source files supported by ESLint config
CLIENT_ESLINT_FILES=$(echo "$CHANGED_FILES" | grep "^client/" | grep -E '\.(ts|tsx|mts|cts|js|jsx|vue)$' | sed 's|^client/||' || true)
if [ -n "$CLIENT_ESLINT_FILES" ]; then
  echo "Linting client files..."
  cd client
  npx eslint $CLIENT_ESLINT_FILES
  cd ..
fi

# Lint only changed server source files supported by ESLint config
SERVER_ESLINT_FILES=$(echo "$CHANGED_FILES" | grep "^server/" | grep -E '\.(ts|tsx|mts|cts|js|jsx|cjs)$' | sed 's|^server/||' || true)
if [ -n "$SERVER_ESLINT_FILES" ]; then
  echo "Linting server files..."
  cd server
  npx eslint --config ./eslint.config.mjs $SERVER_ESLINT_FILES
  cd ..
fi

