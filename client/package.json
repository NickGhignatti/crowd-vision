    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
