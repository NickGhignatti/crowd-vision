{
  "name": "socket-service",
  "version": "9.9.9-test",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint .",
    "lint:fix": "prettier --write src tsconfig.json tsconfig.build.json package.json && eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@crowdvision/eslint-config": "file:../../tooling/eslint-config",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "prettier": "3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "path-to-regexp": ">=8.3.1",
    "brace-expansion": ">=1.1.13",
    "qs": ">=6.15.2",
    "handlebars": ">=4.7.9",
    "socket.io-parser": ">=4.2.6",
    "ws": ">=8.20.1",
    "yauzl": ">=3.2.1"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/?(*.)+(spec|test).ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "setupFilesAfterEnv": [
      "./__tests__/setup.ts"
    ],
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!src/**/*.d.ts"
    ],
    "coverageReporters": [
      "text-summary",
      "json-summary",
      "lcov"
    ]
  }
}
