        H3 -->|"CanManageDomain check"| SVC
        H4 -->|"self, or CanManageDomain"| SVC
        H5 -->|"CanManageDomain check"| SVC
        H6 -->|"CanManageDomain check"| SVC
        H7 --> SVC
        I1 --> SVC
        I2 --> SVC
        I3 --> SVC
        SVC --> STORE
        REDIS["events/account_deleted.go\nRedis Streams consumer"] --> SVC

