(require_gateway_auth) {
    forward_auth claims-gateway:3000 {
        uri /verify
        copy_headers X-Gateway-Claims
    }
}

:80 {
    # Enable compression using Zstandard
    encode zstd gzip

    # ── CORS ─────────────────────────────────────────────────────────────────

    @cors_preflight {
        method OPTIONS
        header Origin *
    }

    handle @cors_preflight {
        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, Accept, Cookie"
        header Access-Control-Allow-Credentials "true"
        header Access-Control-Max-Age "86400"
        respond "" 204
    }

    header Access-Control-Allow-Origin "{http.request.header.Origin}"
    header Access-Control-Allow-Credentials "true"

    # ── Claims Gateway (Keycloak token exchange, /me, JWKS) ─────────────────────
    handle_path /gateway/* {
        reverse_proxy claims-gateway:3000
    }

    # ── Tenancy Service (domains, subdomains, invite codes) ─────────────────────
    handle_path /tenancy/* {
        import require_gateway_auth
        reverse_proxy tenancy-service:3000
    }

    # ── Digital Twin service ──────────────────────────────────────────────────
    handle_path /twin/* {
        import require_gateway_auth
        reverse_proxy twin-service:3000
    }

    # ── Sensor Simulator (TP) ─────────────────────────────────────────────────
    handle_path /simulator/tp/* {
        reverse_proxy sensor-simulator:3000
    }

    # ── Air Quality Simulator (AQ) ────────────────────────────────────────────
    handle_path /simulator/aq/* {
        reverse_proxy aq-simulator:3000
    }

    # ── Notification service ──────────────────────────────────────────────────
    handle_path /notification/* {
        import require_gateway_auth
        reverse_proxy notification-service:3000
    }

    # ── Agent service ─────────────────────────────────────────────────────────
    handle_path /agent/* {
        reverse_proxy agent-service:3000 {
            header_up -X-Gateway-Claims
        }
    }

    # ── Chat service ──────────────────────────────────────────────────────────
    handle_path /chat/* {
        import require_gateway_auth
        reverse_proxy chat-service:3000
    }

    # ── Contracts Service ───────────────────────────────────────────────────────
    handle_path /contracts {
        import require_gateway_auth
        reverse_proxy contracts-service:3000
    }
    handle_path /contracts/* {
        import require_gateway_auth
        reverse_proxy contracts-service:3000
    }

    # ── Socket.IO server ──────────────────────────────────────────────────────
    handle /socket.io/* {
        import require_gateway_auth
        reverse_proxy socket-server:3000
    }

    # ── Signal sensor service ─────────────────────────────────────────────────
    handle /sensor/ingest {
        uri strip_prefix /sensor
        reverse_proxy sensor-service:3000
    }
    handle_path /sensor/* {
        import require_gateway_auth
        reverse_proxy sensor-service:3000
    }

    # ── Mongo Express GUIs ────────────────────────────────────────────────────
    handle /twin-db-gui/* {
        reverse_proxy twin-db-express:8081
    }

    handle /sensor-db-gui/* {
        reverse_proxy sensor-db-express:8081
    }

    handle /notification-db-gui/* {
        reverse_proxy notification-db-express:8081
    }

    handle /contracts-db-gui/* {
        reverse_proxy contracts-service-db-express:8081
    }

    handle /chat-db-gui/* {
        reverse_proxy chat-db-express:8081
    }

    # ── Observability ─────────────────────────────────────────────────────────
    handle_path /prometheus/* {
        reverse_proxy prometheus:9090
    }

    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # Langfuse (LLM trace UI). Served on its own host port 3030 — the prebuilt
    # image inlines its base path at build time, so a subpath reverse_proxy would
    # break static assets. Redirect to the direct port instead.
    handle /langfuse* {
        redir {http.request.scheme}://{http.request.host}:3030 permanent
    }
}
