FROM node:24-alpine

WORKDIR /app

ARG SERVICE_DIR
ARG ARTIFACT_PATH

# package.json/lockfile come from source (context is the repo root); the
# compiled dist/ comes from the CI job's uploaded artifact, not a fresh build.
COPY ${SERVICE_DIR}/package*.json ./
RUN npm ci --omit=dev

COPY ${ARTIFACT_PATH} ./dist

CMD ["node", "dist/index.js"]
